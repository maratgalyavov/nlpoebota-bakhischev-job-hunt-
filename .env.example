APP_NAME=HR Career Assistant
APP_ENV=dev
LOG_LEVEL=INFO

TELEGRAM_BOT_TOKEN=
LLM_API_KEY=
YANDEX_CLOUD_FOLDER_ID=

# Docker-safe cloud baseline with Yandex AI Studio.
LLM_MODEL=qwen2.5-7b-instruct
LLM_PROVIDER=yandex_cloud
LLM_BASE_URL=https://llm.api.cloud.yandex.net/v1
LLM_DEVICE=auto
LLM_MAX_NEW_TOKENS=384
LLM_TEMPERATURE=0.2

# Native macOS M-series preset if you want a smarter local model:
# LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# LLM_PROVIDER=local_hf
# LLM_DEVICE=mps
# LLM_MAX_NEW_TOKENS=512
# LLM_TEMPERATURE=0.15

EMBEDDING_MODEL=text-search-doc
EMBEDDING_QUERY_MODEL=text-search-query
EMBEDDING_PROVIDER=yandex_cloud
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://llm.api.cloud.yandex.net/v1
EMBEDDING_DEVICE=auto
# For native macOS on Apple Silicon:
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
# EMBEDDING_DEVICE=mps
SQLITE_PATH=data/app.db
FAISS_INDEX_PATH=data/faiss/vacancies.index
VACANCIES_PATH=data/mock_vacancies.json
PARSER_AREA=113
PARSER_PAGES_PER_QUERY=5
PARSER_DAILY_PAGES_PER_QUERY=10
PARSER_SEARCH_PERIOD_DAYS=30
PARSER_DAILY_SEARCH_PERIOD_DAYS=3
PARSER_DELAY_SECONDS=0.35
PARSER_MAX_VACANCIES=0
# Optional override, separated by | or new lines:
# PARSER_QUERIES=Python developer|Backend developer|аналитик данных
BOT_BACKEND_URL=http://127.0.0.1:8000
BOT_BACKEND_TIMEOUT_SECONDS=120

USE_MOCK_LLM=false
USE_MOCK_EMBEDDINGS=false
PRELOAD_MODELS_ON_STARTUP=false
# For native launchd runs on a Mac, prefer:
# PRELOAD_MODELS_ON_STARTUP=false
